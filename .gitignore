# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables — never commit secrets
.env
.env.*
!.env.example

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Node
node_modules/
.npm

# Next.js
frontend/.next/
frontend/out/

# Logs
*.log
npm-debug.log*

# Data cache (runtime-generated)
data/cache/
backend/data/cache/

# HuggingFace model cache (auto-downloaded on first run)
.cache/
backend/.cache/

# OS artifacts
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Compiled binaries
*.so
*.dylib
