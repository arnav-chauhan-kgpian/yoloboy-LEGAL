# LexGraph AI — environment variables
# Copy to backend/.env and fill in your values

# Required: Groq API key (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Set this to your Railway frontend URL after deploying
# CORS_ORIGINS=https://your-frontend.up.railway.app

# Optional overrides
# LOG_LEVEL=INFO
# DATA_PATH=../data
